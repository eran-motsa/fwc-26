# ── API keys ────────────────────────────────────────────────────────────────
# Fixtures + team history — free at football-data.org  (register → My Account → API key)
FD_KEY=

# Match-day lineups — free at api-football.com  (direct, NOT via RapidAPI)
API_FOOTBALL_KEY=

# Odds — free at the-odds-api.com  (500 credits/month)
ODDS_API_KEY=

# ── Config (sane defaults, change only if you know why) ──────────────────────
WC_LEAGUE_ID=1
WC_SEASON=2026
TZ_LOCAL=Asia/Jerusalem
DB_PATH=data/mundial.db
ODDS_REGIONS=eu,uk
